# AMD Fleet Monitor — Environment Variables
# Copy to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql+asyncpg://fleetmon:your_secure_password_here@localhost:5432/fleetmon

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── App Security ──────────────────────────────────────────────────────────
SECRET_KEY=your-256-bit-secret-key-here

# ── Azure AD (for SSO) ────────────────────────────────────────────────────
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# ── HashiCorp Vault (for BMC credentials) ─────────────────────────────────
VAULT_URL=http://vault.amd.com:8200
VAULT_TOKEN=your-vault-token
# OR use AppRole:
# VAULT_ROLE_ID=
# VAULT_SECRET_ID=

# ── Email Alerting ────────────────────────────────────────────────────────
SMTP_HOST=smtp.amd.com
SMTP_PORT=587
SMTP_USER=fleet-monitor@amd.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=fleet-monitor@amd.com

# ── Microsoft Teams Alerting ──────────────────────────────────────────────
TEAMS_WEBHOOK_URL=https://amd.webhook.office.com/webhookb2/...

# ── Slack Alerting ────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL=#server-alerts

# ── Frontend ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Grafana ───────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=your-grafana-admin-password

# ── Example AMD Server BMC Credentials (store in Vault, not here) ─────────
# volcano-eb87.amd.com BMC → store in Vault at secret/fleet-monitor/servers/<server-id>
# titanite-d310.amd.com BMC → store in Vault at secret/fleet-monitor/servers/<server-id>
# daytonax42cd.amd.com BMC → store in Vault at secret/fleet-monitor/servers/<server-id>
